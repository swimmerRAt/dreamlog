SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Ollama 설정 (기본값: 로컬)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
VISION_MODEL=llava
TEXT_MODEL=llama3.2
# 독소조항 탐지용 커스텀 모델명 (llm.modelfile.create_toxic_detector로 생성)
TOXIC_DETECTOR_MODEL=dreamlog-toxic-detector

DATABASE_URL=sqlite:///./dreamlog.db
